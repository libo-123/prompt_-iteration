{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": ".cursor/hooks/format.sh"
      }
    ],
    "preToolUse": [
      {
        "command": "node .cursor/hooks/skill_trace_logger.js preToolUse"
      }
    ],
    "afterAgentResponse": [
      {
        "command": "node .cursor/hooks/skill_trace_logger.js afterAgentResponse"
      }
    ],
    "postToolUse": [
      {
        "command": "node .cursor/hooks/skill_trace_logger.js postToolUse"
      }
    ],
    "postToolUseFailure": [
      {
        "command": "node .cursor/hooks/skill_trace_logger.js postToolUseFailure"
      }
    ],
    "stop": [
      {
        "command": "node .cursor/hooks/skill_trace_logger.js stop"
      }
    ]
  }
}